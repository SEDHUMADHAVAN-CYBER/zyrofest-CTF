<!DOCTYPE html>
<html>
<head>
    <title>ZYROFEST-{CTF} ADMIN</title>
    <link rel="stylesheet" href="/static/style.css">
    <style>
        .admin-nav { display: flex; gap: 15px; margin-bottom: 25px; flex-wrap: wrap; }
        .admin-nav a button { width: auto; font-size: 14px; }
    </style>
</head>
<body>

<div class="nav">
    <div class="left">
        <div class="logo">MANAGE CHALLENGES</div>
        <a href="/admin/dashboard">DASHBOARD</a>
    </div>
</div>

<div class="container">
    <div class="admin-nav">
        <a href="/admin/users"><button>👥 USERS</button></a>
        <a href="/admin/teams"><button>🛡️ TEAMS</button></a>
        <a href="/admin/challenges"><button style="background:var(--text-color); color:black;">🎯 CHALLENGES</button></a>
        <a href="/admin/settings"><button>⚙️ SETTINGS</button></a>
    </div>

    <% if (messages.success) { %><p class="msg success"><%= messages.success %></p><% } %>
    <% if (messages.error) { %><p class="msg error"><%= messages.error %></p><% } %>

    <div class="card" style="margin-top: 20px;">
        <h3>ADD NEW CHALLENGE</h3>
        <!-- Note the enctype for file uploads -->
        <form class="form-box" method="POST" action="/admin/challenge" enctype="multipart/form-data" style="margin-top: 10px;">
            <input type="text" name="title" placeholder="CHALLENGE TITLE" required>
            <textarea name="description" placeholder="CHALLENGE DESCRIPTION (HTML supported)" rows="4" required></textarea>
            <input type="text" name="category" placeholder="CATEGORY (e.g. WEB, CRYPTO)" required>
            <input type="number" name="points" placeholder="POINTS" required>
            <input type="text" name="flag" placeholder="FLAG (e.g. ZYROFEST-{CTF}{...})" required>
            
            <p style="margin-bottom:5px; font-size:12px;">UPLOAD FILE OR PROVIDE URL (Optional)</p>
            <input type="file" name="challenge_file" style="padding:8px; background: rgba(0,255,204,0.1);">
            <input type="text" name="file_url" placeholder="EXTERNAL FILE URL (If not uploading a file)">
            
            <input type="number" name="sort_order" placeholder="SORT ORDER (e.g. 1)" value="0">
            <button type="submit">ADD CHALLENGE</button>
        </form>
    </div>

    <div class="card" style="margin-top: 20px;">
        <h3>EXISTING CHALLENGES</h3>
        <table style="font-size: 14px;">
            <tr>
                <th>ORDER</th>
                <th>TITLE</th>
                <th>CATEGORY</th>
                <th>POINTS</th>
                <th>ACTION</th>
            </tr>
            <% challenges.forEach(function(c) { %>
            <tr>
                <td><%= c.sort_order %></td>
                <td><%= c.title %></td>
                <td><%= c.category %></td>
                <td><%= c.points %></td>
                <td style="display:flex; gap:10px;">
                    <a href="/admin/edit-challenge/<%= c.id %>"><button style="padding:5px 10px; font-size:12px;">EDIT</button></a>
                    <form method="POST" action="/admin/challenge/<%= c.id %>/delete" style="display:inline;">
                        <button type="submit" style="padding:5px 10px; font-size:12px; border-color:red; color:red;">DELETE</button>
                    </form>
                </td>
            </tr>
            <% }); %>
        </table>
    </div>

</div>

</body>
</html>
