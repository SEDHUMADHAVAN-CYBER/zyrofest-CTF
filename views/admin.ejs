<!DOCTYPE html>
<html>
<head>
    <title>ZYROFEST-{CTF}</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>

<!-- 🔥 NAVBAR -->
<div class="nav">
    <div class="left">
        <div class="logo">ZYROFEST-{CTF}</div>
        <a href="/dashboard">DASHBOARD</a>
        <a href="/scoreboard">SCOREBOARD</a>
        <a href="/team">TEAM</a>
        <a href="/profile">PROFILE</a>
    </div>
    <div class="right">
        <button onclick="toggleTheme()" id="themeBtn" class="theme-btn">🌙</button>
        <% if (user) { %>
            <a href="/logout">LOGOUT</a>
        <% } %>
    </div>
</div>

<!-- 🔥 CONTENT -->
<div class="container">
    <h2>ADMIN PANEL</h2>

    <% if (messages.error) { %>
        <p class="msg error"><%= messages.error %></p>
    <% } %>
    <% if (messages.success) { %>
        <p class="msg success"><%= messages.success %></p>
    <% } %>

    <!-- EVENT CONTROL & NOTIFICATIONS -->
    <div class="grid">
        <div class="card">
            <h3>EVENT CONTROL</h3>
            <form method="POST" action="/admin/pause">
                <button type="submit" style="background: <%= ctf_paused ? 'lime' : 'red' %>; color: black;">
                    <%= ctf_paused ? 'RESUME CTF' : 'PAUSE CTF' %>
                </button>
            </form>
        </div>

        <div class="card">
            <h3>ANNOUNCEMENT</h3>
            <form method="POST" action="/admin/notification">
                <textarea name="message" placeholder="ENTER NOTIFICATION MESSAGE" rows="3" required></textarea>
                <button type="submit">POST NOTIFICATION</button>
            </form>
            <hr style="border: 1px solid #333; margin: 15px 0;">
            <table style="font-size: 10px; width: 100%;">
                <% notificationsList.forEach(function(n) { %>
                    <tr>
                        <td style="text-align: left;"><%= n.message %></td>
                        <td style="width: 80px;">
                            <form method="POST" action="/admin/notification/<%= n.id %>/delete" style="display:inline;">
                                <button type="submit" style="width:auto; padding:5px 10px; margin:0; font-size:10px;">DELETE</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </table>
        </div>
    </div>

    <!-- ADD CHALLENGE -->
    <div class="card">
        <h3>ADD CHALLENGE</h3>
        <form method="POST" action="/admin/challenge">
            <input type="text" name="title" placeholder="TITLE" required>
            <textarea name="description" placeholder="DESCRIPTION" rows="4" required></textarea>
            <select name="category" required>
                <option value="">SELECT CATEGORY</option>
                <option value="OSINT">OSINT</option>
                <option value="CRYPTO">CRYPTO</option>
                <option value="FORENSICS">FORENSICS</option>
                <option value="MISC">MISC</option>
                <option value="WEB">WEB</option>
                <option value="REV">REV</option>
            </select>
            <input type="number" name="points" placeholder="POINTS" required>
            <input type="text" name="flag" placeholder="FLAG" required>
            <button type="submit">ADD CHALLENGE</button>
        </form>
    </div>

    <!-- ALL CHALLENGES -->
    <div class="card">
        <h3>ALL CHALLENGES</h3>
        <table>
            <tr>
                <th>ID</th>
                <th>TITLE</th>
                <th>CATEGORY</th>
                <th>POINTS</th>
                <th>ACTION</th>
            </tr>
            <% challenges.forEach(function(c) { %>
                <tr>
                    <td><%= c._id %></td>
                    <td><%= c.title %></td>
                    <td><%= c.category %></td>
                    <td><%= c.points %></td>
                    <td>
                        <a href="/admin/edit-challenge/<%= c._id || c.id %>">
                            <button style="width:auto; padding:8px 12px; margin:0;">EDIT</button>
                        </a>
                        <form method="POST" action="/admin/challenge/<%= c._id || c.id %>/delete" style="display:inline;">
                            <button type="submit" style="width:auto; padding:8px 12px; margin:0;">DELETE</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
        </table>
    </div>

    <!-- ALL USERS -->
    <div class="card">
        <h3>ALL USERS</h3>
        <table style="font-size: 10px;">
            <tr>
                <th>ID</th>
                <th>USERNAME</th>
                <th>TEAM</th>
                <th>SCORE</th>
                <th>ACTION</th>
            </tr>
            <% users.forEach(function(u) { %>
                <tr>
                    <td><%= u.id %></td>
                    <td><%= u.username %></td>
                    <form method="POST" action="/admin/edit-user/<%= u.id %>">
                        <td><input type="text" name="team_name" value="<%= u.team_name || '' %>" placeholder="TEAM" style="padding:5px; margin:0; width:100px;"></td>
                        <td><input type="number" name="score" value="<%= u.score %>" style="padding:5px; margin:0; width:80px;"></td>
                        <td><button type="submit" style="width:auto; padding:8px 12px; margin:0;">SAVE</button></td>
                    </form>
                </tr>
            <% }); %>
        </table>
    </div>
</div>

<!-- 🔥 FOOTER -->
<footer class="footer">
    <p>Developed by <b>sedhu madhavan</b></p>
</footer>

<!-- 🔥 THEME SCRIPT -->
<script>
function toggleTheme() {
    let body = document.body;
    if (body.classList.contains("dark")) {
        body.classList.remove("dark");
        localStorage.setItem("theme", "light");
        document.getElementById("themeBtn").innerText = "🌙";
    } else {
        body.classList.add("dark");
        localStorage.setItem("theme", "dark");
        document.getElementById("themeBtn").innerText = "☀️";
    }
}
window.onload = function() {
    let theme = localStorage.getItem("theme");
    if (theme === "dark") {
        document.body.classList.add("dark");
        document.getElementById("themeBtn").innerText = "☀️";
    }
}
</script>

</body>
</html>
