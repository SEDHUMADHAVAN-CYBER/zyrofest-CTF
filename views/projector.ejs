<!DOCTYPE html>
<html>
<head>
    <title>LIVE LEADERBOARD | ZYROFEST-{CTF}</title>
    <link rel="stylesheet" href="/static/style.css">
    <meta http-equiv="refresh" content="10">
    <style>
        body {
            background: #050505;
            background-image: radial-gradient(circle at center, #111 0%, #000 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }
        .projector-container {
            width: 90%;
            max-width: 1400px;
        }
        .title-glitch {
            font-size: 64px;
            color: var(--accent-color);
            text-align: center;
            text-transform: uppercase;
            font-family: var(--font-heading);
            letter-spacing: 5px;
            margin-bottom: 20px;
            text-shadow: 0 0 20px var(--accent-color);
        }
        .announcement-bar {
            background: rgba(0, 255, 204, 0.1);
            border: 2px solid var(--text-color);
            padding: 20px;
            text-align: center;
            font-size: 24px;
            margin-bottom: 40px;
            box-shadow: 0 0 20px rgba(0, 255, 204, 0.2);
        }
        .leaderboard-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 10px;
        }
        .leaderboard-table th {
            background: transparent;
            color: var(--text-color);
            font-size: 24px;
            padding: 15px;
            border: none;
            border-bottom: 2px solid var(--text-color);
            text-shadow: 0 0 10px var(--text-color);
        }
        .leaderboard-table td {
            background: rgba(255,255,255,0.02);
            padding: 20px 15px;
            font-size: 28px;
            border: none;
            border-top: 1px solid #222;
            border-bottom: 1px solid #222;
            transition: all 0.3s;
        }
        .leaderboard-table tr:hover td {
            background: rgba(0,255,204,0.05);
            border-color: var(--text-color);
        }
        .rank-badge {
            display: inline-block;
            width: 50px;
            height: 50px;
            line-height: 50px;
            text-align: center;
            background: var(--text-color);
            color: #000;
            border-radius: 50%;
            font-family: var(--font-heading);
            font-weight: 900;
        }
        .r1 { background: gold; box-shadow: 0 0 20px gold; }
        .r2 { background: silver; box-shadow: 0 0 20px silver; }
        .r3 { background: #cd7f32; box-shadow: 0 0 20px #cd7f32; }
    </style>
</head>
<body>

<div class="projector-container">
    <h1 class="title-glitch">ZYROFEST-{CTF} LIVE</h1>

    <% if (notification) { %>
        <div class="announcement-bar">
            <strong>📢 ANNOUNCEMENT:</strong> <%= notification.message %>
        </div>
    <% } %>

    <table class="leaderboard-table">
        <tr>
            <th style="width: 100px; text-align: center;">RANK</th>
            <th>USER / TEAM</th>
            <th style="text-align: right;">SCORE</th>
        </tr>
        <% users.forEach(function(u, i) { %>
        <tr>
            <td style="text-align: center;">
                <span class="rank-badge <%= i === 0 ? 'r1' : i === 1 ? 'r2' : i === 2 ? 'r3' : '' %>"><%= i + 1 %></span>
            </td>
            <td>
                <span style="color: white; font-weight: bold;"><%= u.username %></span>
                <% if (u.team_name) { %>
                    <span style="font-size: 16px; color: var(--accent-color); margin-left: 15px;">[<%= u.team_name %>]</span>
                <% } %>
            </td>
            <td style="text-align: right; color: lime; font-family: var(--font-heading); font-size: 32px;"><%= u.score %></td>
        </tr>
        <% }); %>
    </table>
</div>

</body>
</html>
