# ============================================================
# ZYROFEST CTF - Environment Variables Example
# Copy this file to .env and fill in real values
# ============================================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/ymmwszzwbacjiisifkyb/settings/api
SUPABASE_URL=https://ymmwszzwbacjiisifkyb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=your-super-secret-random-string-here

# Admin Credentials
ADMIN_USERNAME=admin@yourdomain.com
ADMIN_PASSWORD=your-strong-password-here

# CTF Flags (NEVER hardcode these in source)
FLAG_1=ZYROFEST-{CTF}{...}
FLAG_2=ZYROFEST-{CTF}{...}
FLAG_3=ZYROFEST-{CTF}{...}
FLAG_4=ZYROFEST-{CTF}{...}
FLAG_5=ZYROFEST-{CTF}{...}
FLAG_6=ZYROFEST-{CTF}{...}

# Node Environment
NODE_ENV=development
PORT=3000
